---
import Base from '../layouts/Base.astro';
import { render } from 'astro:content';
import { publishedPosts } from '../lib/posts';
import Comments from '../components/Comments.astro';

export async function getStaticPaths() {
  const posts = await publishedPosts();
  return posts.map((post) => ({
    params: { permalink: post.data.permalink },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<Base
  title={`${post.data.title} - Prompting BI`}
  description={post.data.description}
  ogImage={post.data.featured}
>
  <article>
    <h1>{post.data.title}</h1>
    <p class="post-date">{fmt(post.data.date)} · Tommy Puglia</p>
    {post.data.featured && (
      <img class="post-banner" src={post.data.featured} alt={`Banner illustration for ${post.data.title}`} />
    )}
    <Content />
    <Comments />
  </article>
</Base>
