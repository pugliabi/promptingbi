---
import Base from '../layouts/Base.astro';
import { publishedPosts } from '../lib/posts';

const posts = await publishedPosts();
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<Base>
  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <h2><a href={`/${post.data.permalink}/`}>{post.data.title}</a></h2>
        {post.data.featured && (
          <a class="post-thumb" href={`/${post.data.permalink}/`}>
            <img src={post.data.featured} alt={`Banner illustration for ${post.data.title}`} loading="lazy" />
          </a>
        )}
        <p class="post-date">{fmt(post.data.date)}</p>
        {post.data.description && <p>{post.data.description}</p>}
        <a class="read-more" href={`/${post.data.permalink}/`}>Read More →</a>
      </li>
    ))}
  </ul>
</Base>
