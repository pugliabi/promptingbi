---
import Base from '../layouts/Base.astro';
---
<Base title="Search - Prompting BI" description="Search Prompting BI posts">
  <article>
    <h1>Search</h1>
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
    <div id="search"></div>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (window.PagefindUI) {
          new window.PagefindUI({ element: '#search', showSubResults: true });
        } else {
          document.getElementById('search').textContent =
            'Search index not found — it is generated during the production build (npm run build).';
        }
      });
    </script>
    <noscript><p>Search requires JavaScript.</p></noscript>
  </article>
</Base>
