---
/**
 * giscus comments — powered by GitHub Discussions on pugliabi/promptingbi.
 *
 * ONE-TIME SETUP (5 minutes):
 *  1. Repo Settings → General → Features → enable "Discussions"
 *  2. Install the giscus app: https://github.com/apps/giscus (grant it this repo)
 *  3. Go to https://giscus.app, enter pugliabi/promptingbi, pick the
 *     "Announcements" category, mapping = pathname
 *  4. Copy the generated data-repo-id and data-category-id into the
 *     constants below and set ENABLED = true
 */
const ENABLED = false;
const REPO = 'pugliabi/promptingbi';
const REPO_ID = 'FILL_ME_FROM_GISCUS_APP';
const CATEGORY = 'Announcements';
const CATEGORY_ID = 'FILL_ME_FROM_GISCUS_APP';
---

{
  ENABLED && (
    <section class="comments" aria-label="Comments">
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo={REPO}
        data-repo-id={REPO_ID}
        data-category={CATEGORY}
        data-category-id={CATEGORY_ID}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="light"
        data-lang="en"
        crossorigin="anonymous"
        async
      />
    </section>
  )
}

<style>
  .comments {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
</style>
